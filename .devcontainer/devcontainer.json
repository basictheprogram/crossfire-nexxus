{
    "name": "cross-fire.org nexxus-ninja",
    "dockerComposeFile": [
        "compose.yml"
    ],
    "service": "vscode",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",
    "features": {
        "ghcr.io/dhoeric/features/hadolint:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "batisteo.vscode-django",
                "aaron-bond.better-comments",
                "shardulm94.trailing-spaces",
                "eamodio.gitlens",
                "redhat.vscode-yaml",
                "yzhang.markdown-all-in-one",
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "mrmlnc.vscode-apache",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "stylelint.vscode-stylelint",
                "HTMLHint.vscode-htmlhint",
                "pranaygp.vscode-css-peek",
                "formulahendry.auto-close-tag",
                "formulahendry.auto-rename-tag",
                "ms-azuretools.vscode-docker",
                "GitHub.copilot",
                "tomoki1207.pdf",
                "ms-vscode.makefile-tools",
                "humao.rest-client"
            ],
            "settings": {
                // Python
                "python.defaultInterpreterPath": "/home/vscode/.venv/bin/python3",
                "python.analysis.autoImportCompletions": true,
                // Ruff
                "ruff.enable": true,
                "ruff.organizeImports": true,
                // Editor behavior
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "[html]": {
                    "editor.formatOnSave": false
                },
                // Terminal / container
                "terminal.integrated.wordWrap": "off",
                "remote.containers.logLevel": "debug",
                // PHP
                "php.validate.enable": true,
                "intelephense.diagnostics.enable": true
            }
        }
    },
    "containerEnv": {
        "VIRTUAL_ENV": "/home/vscode/.venv",
        "PYTHONUNBUFFERED": "True",
        "UV_LINK_MODE": "copy",
        "UV_PROJECT_ENVIRONMENT": "/home/vscode/.venv",
        "DISPLAY": "dummy"
    },
    "forwardPorts": [
        80,
        443,
        3306
    ],
    "postCreateCommand": "./.devcontainer/postCreateCommand.sh",
    "postStartCommand": "uv tool run pre-commit install",
    "remoteUser": "vscode"
}
